{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "Installer training courses shown in the Training Academy section"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "icon": {
      "type": "string",
      "required": true,
      "description": "Key into the frontend's Icon.tsx registry"
    },
    "iconColor": {
      "type": "string",
      "customField": "global::color",
      "required": true,
      "default": "#3B82F6",
      "description": "Icon badge and accent color for this course"
    }
  }
}
