{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post",
    "description": "Articles shown on /blog and /blog/[slug]"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "string",
      "required": true,
      "description": "Display category label, e.g. \"Security\", \"Solar Energy\""
    },
    "date": {
      "type": "string",
      "required": true,
      "description": "Plain display string in \"Month D, YYYY\" format, not parsed — matches the site's existing convention"
    },
    "author": {
      "type": "string",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    }
  }
}
