{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service",
    "description": "Installation and support services offered alongside the product catalog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 150
    },
    "description": {
      "type": "text",
      "required": true,
      "maxLength": 2000
    },
    "features": {
      "type": "json",
      "required": true,
      "description": "Array of short feature/bullet strings, e.g. [\"Site survey\", \"Cabling\"]"
    },
    "icon": {
      "type": "string",
      "required": true
    },
    "iconColor": {
      "type": "string",
      "customField": "global::color",
      "required": true,
      "default": "#3B82F6",
      "description": "Icon badge and accent color for this service"
    }
  }
}
