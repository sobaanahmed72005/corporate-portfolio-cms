{
  "kind": "collectionType",
  "collectionName": "offices",
  "info": {
    "singularName": "office",
    "pluralName": "offices",
    "displayName": "Office",
    "description": "Office/branch listing shown in the offices section and contact page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "address": {
      "type": "text",
      "required": true
    },
    "icon": {
      "type": "string",
      "required": true
    },
    "iconColor": {
      "type": "string",
      "customField": "global::color",
      "required": true,
      "default": "#3B82F6",
      "description": "Icon badge color for this office"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Optional real office photo — falls back to an empty photo slot when unset"
    },
    "displayOrder": {
      "type": "integer",
      "required": true,
      "default": 0,
      "description": "Controls the order offices appear in on the site — lower numbers show first (e.g. 1, 2, 3)"
    }
  }
}
