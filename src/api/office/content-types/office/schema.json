{
  "kind": "collectionType",
  "collectionName": "offices",
  "info": {
    "singularName": "office",
    "pluralName": "offices",
    "displayName": "Office",
    "description": "Office/branch listing shown in the offices section and contact page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "address": {
      "type": "text",
      "required": true
    },
    "icon": {
      "type": "string",
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Optional real office photo — falls back to an empty photo slot when unset"
    }
  }
}
