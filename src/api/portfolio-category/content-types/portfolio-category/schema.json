{
  "kind": "collectionType",
  "collectionName": "portfolio_categories",
  "info": {
    "singularName": "portfolio-category",
    "pluralName": "portfolio-categories",
    "displayName": "Portfolio Category",
    "description": "Groups of related past projects, e.g. CCTV Installation Projects"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "icon": {
      "type": "string",
      "required": true,
      "description": "Key into the frontend's Icon.tsx registry, e.g. \"camera\""
    },
    "gradient": {
      "type": "string",
      "required": true,
      "description": "Key into the frontend's gradients.ts GRADIENTS map, e.g. \"rose\""
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Optional real category photo — falls back to the icon badge when unset"
    },
    "projects": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project.project",
      "mappedBy": "category"
    }
  }
}
